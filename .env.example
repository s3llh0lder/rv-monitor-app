# Copy to .env and fill in. Leave MAIL_USERNAME blank to log alerts instead of emailing.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TO=you@example.com
MAIL_FROM=rv-monitor@example.com

# How often to poll, in ms (default 15 min)
RV_CHECK_INTERVAL=900000
RV_POLITE_INTER_DELAY_MS=3000
RV_POLITE_JITTER_MAX_MS=30000
RICHMOND_WATCH_ENABLED=true
OUTDOORSY_WATCH_ENABLED=true

# Optional RVezy authenticated mode (full JSON API). Leave blank for public SSR
# scraping. Capture from a logged-in browser — these are TOKENS, not a password.
RVEZY_BEARER_TOKEN=
RVEZY_REFRESH_TOKEN=

# Optional CanaDream (THL cosmos) — EXPERIMENTAL. Capture the auth header value
# from a live booking session at canadream.sci.thlonline.com (DevTools → Network
# → a /products request). Leave blank to skip CanaDream.
CANADREAM_API_TOKEN=
CANADREAM_WATCH_ENABLED=false
